# 1. 安装必要包
pip install torch numpy scipy matplotlib pillow tqdm tensorboard

# 2. （可选）安装 tinycudann 加速
pip install git+https://github.com/NVlabs/tiny-cuda-nn/#subdirectory=bindings/torch

# 3. 生成合成数据（默认输出到 data/dendrite_v5）
python generate_synthetic_dendrite_v6.py
python train.py \
    --data_json data/dendrite_v5/transforms_00_to_29.json \
    --max_iter 3000 \
    --cp_grid 6 6 6 \
    --batch_size 512 \
    --enable_growth

# 4. 开始训练（默认 3000 步，6³ 控制点）
python train.py --data_json data/dendrite_v5/transforms_00_to_29.json --max_iter 3000 --cp_grid 6 6 6

# 5. （可选）蒸馏到更高分辨率
python refine.py --checkpoint checkpoints/final.ckpt --old_cp_grid 6 6 6 --new_cp_grid 9 9 9 --output refined_9.ckpt

# 6. 导出结果
python export.py --checkpoint final.ckpt --output_dir exports --resolution 128 --export_volume --export_deformation --export_velocity --export_growth

pip install viser
python viser_viewer.py --checkpoint final.ckpt
python viser_viewer.py --checkpoint final.ckpt --render_h 300 --render_w 300
cp final.ckpt /root/logs/
成功

python train.py \
    --data_json data/dendrite_v5/transforms_00_to_29.json \
    --max_iter 8000 \
    --batch_size 384 \
    --dense_batch_size 768 \
    --smoothness_weight 0.02 \
    --mass_weight 0.02 \
    --monotonicity_weight 0.0005 \
    --tv_weight 1e-5 \
    --lr 1e-3 \
    --output_dir ./runs_v3

python export.py --checkpoint runs_v3/checkpoints/final.ckpt --output_dir results_v3 --export_volume --times 0.0 0.5 1.0 --render --render_data data/dendrite_v5/transforms_00_to_29.json